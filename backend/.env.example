# ============================================================
# FlexFlow Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ─── JWT / Security ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database (Google Cloud SQL via Proxy) ──────────────────
# Proxy must be running on port 5434 before starting the backend
# DO NOT use port 5432 — reserved for local Postgres
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5434/DBNAME

# ─── AWS S3 (ONET File Sync) ────────────────────────────────
S3_ACCESS_KEY=REPLACE_WITH_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_S3_SECRET_KEY
S3_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME
S3_REGION=us-east-1

# ─── Google Cloud (GCP Key) ─────────────────────────────────
GCP_KEY_PATH=./gcp-key.json

# ─── Application ────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
UPLOAD_DIR=backend/uploads
